{
  "name": "job-service-node",
  "version": "1.0.0",
  "description": "Job runner boilerplate (cron + PostgreSQL + Redis + RabbitMQ)",
  "main": "src/server.ts",
  "type": "module",
  "scripts": {
    "test": "rm -rf dist && vitest",
    "test:coverage": "rm -rf dist && vitest run --coverage",
    "lint": "eslint 'src/**/*.ts' --fix",
    "dev": "bun run --watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "infra:up": "docker compose -f docker-compose.infra.yml up -d",
    "infra:stop": "docker compose -f docker-compose.infra.yml stop",
    "infra:down": "docker compose -f docker-compose.infra.yml down",
    "infra:clean": "docker compose -f docker-compose.infra.yml down -v --rmi all",
    "app:up": "docker compose up -d app",
    "app:down": "docker stop job_service_node_app",
    "prisma:gen": "npx prisma generate --schema=./prisma/main/schema.prisma",
    "postinstall": "npm run prisma:gen",
    "prepare": "husky"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.7.0",
    "@prisma/client": "^7.7.0",
    "amqp-connection-manager": "^5.0.0",
    "amqplib": "^1.0.3",
    "dotenv": "^17.4.2",
    "ioredis": "^5.10.1",
    "node-cron": "^3.0.3",
    "pg": "^8.20.0",
    "pino": "^10.3.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/amqplib": "^0.10.8",
    "@types/node": "^25.6.0",
    "@types/node-cron": "^3.0.11",
    "@types/pg": "^8.20.0",
    "@typescript-eslint/eslint-plugin": "^8.58.2",
    "@typescript-eslint/parser": "^8.58.2",
    "@vitest/coverage-istanbul": "^4.1.6",
    "@vitest/coverage-v8": "^4.1.4",
    "eslint": "^10.2.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prisma": "^7.7.0",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.2",
    "vitest": "^4.1.4"
  },
  "lint-staged": {
    "src/**/*.ts": [
      "eslint --fix",
      "vitest related --run"
    ]
  }
}
