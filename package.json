{
  "name": "job-service-node",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "test": "rm -rf dist && vitest",
    "test:coverage": "rm -rf dist && vitest run --coverage",
    "lint": "eslint 'src/**/*.ts' --fix",
    "generate": "bun run generator/index.ts",
    "install:storage": "bun run generator/install-storage.ts",
    "dev": "bun run --watch src/server.ts",
    "build": "tsc",
    "start": "node dist/app.js",
    "infra:up": "docker compose -f docker-compose.infra.yml up -d",
    "infra:stop": "docker compose -f docker-compose.infra.yml stop",
    "infra:down": "docker compose -f docker-compose.infra.yml down",
    "infra:clean": "docker compose -f docker-compose.infra.yml down -v --rmi all",
    "metrics:up": "docker compose -f docker-compose.metrics.yml up -d",
    "metrics:stop": "docker compose -f docker-compose.metrics.yml stop",
    "metrics:down": "docker compose -f docker-compose.metrics.yml down",
    "db:up": "docker compose -f docker-compose.infra.yml up -d db",
    "db:down": "docker stop backend_node_db_infra",
    "app:up": "docker compose up -d app",
    "app:down": "docker stop backend_node_app",
    "redis:up": "docker compose -f docker-compose.infra.yml up -d redis",
    "prisma:gen": "npx prisma generate --schema=./prisma/audit/audit.prisma && npx prisma generate --schema=./prisma/main/schema.prisma",
    "prisma:dev": "npx prisma migrate dev --schema=./prisma/main/schema.prisma",
    "prisma:migrate": "npx prisma migrate dev --schema=./prisma/main/schema.prisma --create-only",
    "prisma:deploy:main": "npx prisma migrate deploy --schema=./prisma/main/schema.prisma",
    "prisma:deploy:audit": "npx prisma migrate deploy --schema=./prisma/audit/audit.prisma",
    "prisma:deploy": "npm run prisma:deploy:main && npm run prisma:deploy:audit && npm run seed",
    "postinstall": "npm run prisma:gen",
    "seed": "npx prisma db seed",
    "prepare": "husky"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "dependencies": {
    "@fastify/auth": "^5.0.4",
    "@fastify/compress": "^8.3.1",
    "@fastify/cors": "^11.2.0",
    "@fastify/helmet": "^13.0.2",
    "@fastify/jwt": "^9.1.0",
    "@fastify/rate-limit": "^10.3.0",
    "@fastify/swagger": "^9.7.0",
    "@fastify/swagger-ui": "^5.2.5",
    "@prisma/adapter-pg": "^7.7.0",
    "@prisma/client": "^7.7.0",
    "@sinclair/typebox": "^0.34.49",
    "@testcontainers/postgresql": "^11.14.0",
    "@testcontainers/redis": "^11.14.0",
    "amqp-connection-manager": "^5.0.0",
    "amqplib": "^1.0.3",
    "bcrypt": "^6.0.0",
    "dotenv": "^17.4.2",
    "fastify": "^5.8.5",
    "handlebars": "^4.7.9",
    "ioredis": "^5.10.1",
    "lodash": "^4.18.1",
    "nodemailer": "^8.0.5",
    "opossum": "^9.0.0",
    "pg": "^8.20.0",
    "pino": "^10.3.1",
    "prom-client": "^15.1.3",
    "testcontainers": "^11.14.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@stryker-mutator/core": "^9.6.1",
    "@stryker-mutator/typescript-checker": "^9.6.1",
    "@stryker-mutator/vitest-runner": "^9.6.1",
    "@types/amqplib": "^0.10.8",
    "@types/bcrypt": "^6.0.0",
    "@types/lodash": "^4.17.24",
    "@types/node": "^25.6.0",
    "@types/nodemailer": "^8.0.0",
    "@types/opossum": "^8.1.9",
    "@types/pg": "^8.20.0",
    "@types/supertest": "^7.2.0",
    "@typescript-eslint/eslint-plugin": "^8.58.2",
    "@typescript-eslint/parser": "^8.58.2",
    "@vitest/coverage-istanbul": "^4.1.6",
    "@vitest/coverage-v8": "^4.1.4",
    "eslint": "^10.2.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prisma": "^7.7.0",
    "supertest": "^7.2.2",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.2",
    "vitest": "^4.1.4"
  },
  "lint-staged": {
    "src/**/*.ts": [
      "eslint --fix",
      "vitest related --run"
    ]
  }
}
