        {
          "expr": "sum(rate(business_logins_total[1m])) by (status) * 60",
          "legendFormat": "{{status}}",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Exports (por minuto)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 0 },
      "targets": [
        {
          "expr": "sum(rate(business_exports_total[1m])) by (type) * 60",
          "legendFormat": "{{type}}",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Mensageria (por minuto)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 0 },
      "targets": [
        {
          "expr": "sum(rate(business_messages_published_total[1m])) by (queue) * 60",
          "legendFormat": "pub {{queue}}",
          "refId": "A"
        },
        {
          "expr": "sum(rate(business_messages_consumed_total[1m])) by (queue) * 60",
          "legendFormat": "con {{queue}}",
          "refId": "B"
        }
      ]
    },
    {
      "title": "Audit Drops (acumulado)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "increase(business_audit_drops_total[1m])",
          "legendFormat": "drops",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "custom": { "drawStyle": "bars", "fillOpacity": 80 } }
      }
    },
    {
      "title": "Health Check por Serviço",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 8 },
      "targets": [
        {
          "expr": "business_health_check",
          "legendFormat": "{{service}}",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Requisições por Status Code",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 8 },
      "targets": [
        {
          "expr": "sum(increase(http_requests_total[1m])) by (status)",
          "legendFormat": "{{status}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "custom": { "drawStyle": "bars", "fillOpacity": 80 } }
      }
    },
    {
      "title": "Total de Requisições (RPS)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 16 },
      "targets": [
        {
          "expr": "sum(rate(http_requests_total[2m])) by (path)",
          "legendFormat": "{{path}}",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Latência Média (s)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 16 },
      "targets": [
        {
          "expr": "rate(http_request_duration_seconds_sum[1m]) / rate(http_request_duration_seconds_count[1m])",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Uso de Memória",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 16 },
      "targets": [
        { "expr": "process_resident_memory_bytes", "legendFormat": "RSS", "refId": "A" },
        { "expr": "nodejs_heap_size_total_bytes", "legendFormat": "Heap", "refId": "B" }
      ],
      "fieldConfig": { "defaults": { "unit": "bytes" } }
    },
    {
      "title": "Uso de CPU",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 24 },
      "targets": [
        { "expr": "rate(process_cpu_user_seconds_total[1m])", "legendFormat": "User", "refId": "A" },
        { "expr": "rate(process_cpu_system_seconds_total[1m])", "legendFormat": "System", "refId": "B" }
      ],
      "fieldConfig": { "defaults": { "unit": "percentunit" } }
    },
    {
      "title": "Event Loop Lag",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 24 },
      "targets": [
        { "expr": "nodejs_eventloop_lag_seconds", "legendFormat": "Lag", "refId": "A" }
      ],
      "fieldConfig": { "defaults": { "unit": "s" } }
    },
    {
      "title": "Conexões ao Banco",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 24 },
      "targets": [
        { "expr": "db_pool_connections", "legendFormat": "{{database}} {{state}}", "refId": "A" }
      ]
    },
    {
      "title": "Queries no Banco (por minuto)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 32 },
      "targets": [
        { "expr": "sum(rate(db_queries_total[1m])) by (database,status) * 60", "legendFormat": "{{database}} {{status}}", "refId": "A" }
      ]
    },
    {
      "title": "Taxa de Exceções (por minuto)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 32 },
      "targets": [
        { "expr": "sum(rate(nodejs_errors_total[1m])) by (type) * 60", "legendFormat": "{{type}}", "refId": "A" }
      ]
    }
  ],
