ENVIRONMENT=local

LOG_LEVEL=info
SHUTDOWN_TIMEOUT_MS=30000
JOB_EXECUTION_TIMEOUT_MS=300000

# DATABASE (gerenciado pelo backend-node)
DATABASE_URL=postgresql://postgres:postgrespw@localhost:5432/backend_node?schema=public
DATABASE_POOL_MAX=20
DATABASE_POOL_IDLE_TIMEOUT=30000
DATABASE_POOL_CONNECTION_TIMEOUT=5000
DATABASE_QUERY_TIMEOUT=10000

# REDIS (gerenciado pelo backend-node)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_COMMAND_TIMEOUT=5000

# RABBITMQ (gerenciado pelo backend-node)
MESSAGING_ENABLED=false
RABBIT_URL=amqp://guest:guest@localhost:5672
RABBIT_USER=guest
RABBIT_PASSWORD=guest
RABBITMQ_PUBLISH_TIMEOUT=5000

# JOBS
HEALTH_CHECK_CRON=*/1 * * * *
HEALTH_CHECK_ENABLED=true
