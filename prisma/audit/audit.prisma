// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  binaryTargets   = ["native"]
  output   = "../../node_modules/@prisma/audit-client"
}

datasource db {
  provider = "postgresql"
}

model Audit { 
  id                      String    @id @default(uuid())
  id_user                 String?   @db.VarChar(255)
  user_name               String?   
  action_type             String?   @db.VarChar(255)
  execute_type            String?   @db.VarChar(255)
  class                   String?   @db.VarChar(255)
  function                String?   @db.VarChar(255)
  params                  String?   @db.Text() 
  raw                     String?   @db.Text()
  table_name              String?   @db.VarChar(255)
  diff_value              String?   @db.Text() 
  error                   String?   @db.Text()
  host                    String?   @db.Text()
  ip                      String?   @db.Text()
  base_url                String?   @db.Text()
  method                  String?   @db.Text()
  hostname                String?   @db.Text()
  original_url             String?   @db.Text()
  created_at              DateTime  @default(now())
  @@map("tb_audit")
  @@index([id_user, created_at])
  @@index([created_at])
  @@index([table_name])
}

model ErrorLog {
  id                      String    @id @default(uuid())
  id_user              String?   
  source                  String?   
  error_message           String?   
  error_data              String?    
  created_at              DateTime  @default(now())
  @@map("tb_error_log")
  @@index([created_at])
}