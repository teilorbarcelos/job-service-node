generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id             String           @id @default(uuid()) @db.VarChar(40)
  name           String           @db.VarChar(255)
  phone          String?          @db.VarChar(15)
  email          String           @unique @db.VarChar(255)
  cognito_id     String?          @unique @db.VarChar(255)
  active         Boolean          @default(true)
  created_at     DateTime         @default(now())
  updated_at     DateTime         @updatedAt @default(now())
  document       String?          @db.VarChar(20)
  is_deleted     Boolean?         @default(false)
  deleted_at     DateTime?
  avatar         String?          @db.VarChar(255)
  id_auth        String?          @unique @db.VarChar(40)
  id_role        String           @db.VarChar(40)
  Auth           Auth?            @relation(fields: [id_auth], references: [id])
  Role           Role            @relation(fields: [id_role], references: [id])
  Products       Product[]

  @@index([is_deleted, active])
  @@index([created_at])
}
model Auth {
  id                          String    @id @default(uuid()) @db.VarChar(40)
  password                    String?   @db.VarChar(255)
  request_password_token      String?   @db.VarChar(255)
  request_password_expiration DateTime?
  retries                     Int       @default(0)
  User                        User?
  first_access                Boolean   @default(true)
  active                      Boolean   @default(true)
  is_deleted                  Boolean?  @default(false)
  deleted_at                  DateTime?
  created_at                  DateTime  @default(now())
  updated_at                  DateTime  @updatedAt
}

model Role {
  id             String           @id @db.VarChar(40)
  name           String           @db.VarChar(255)
  description    String           @db.VarChar(255)
  active         Boolean          @default(true)
  created_at     DateTime         @default(now())
  updated_at     DateTime         @updatedAt @default(now())
  is_deleted     Boolean?         @default(false)
  deleted_at     DateTime?
  Users          User[]
  RoleFeature    RoleFeature[]
}

model RoleFeature  { 
  id_role       String             @db.VarChar(40)
  id_feature    String             @db.VarChar(40)
  create          Boolean          @default(false)
  view            Boolean          @default(false)
  activate        Boolean          @default(false)
  delete          Boolean          @default(false)
  Role          Role               @relation(fields: [id_role], references: [id])
  Feature       Feature            @relation(fields: [id_feature], references: [id])
  @@id([id_feature,id_role])
}

model Feature {
  id             String           @id @db.VarChar(40)
  name           String           @db.VarChar(255)
  description    String
  active         Boolean          @default(true)
  created_at     DateTime         @default(now())
  updated_at     DateTime         @updatedAt @default(now())
  RoleFeature    RoleFeature[]
}



model Product {
  id             String           @id @default(uuid()) @db.VarChar(40)
  name           String           @db.VarChar(255)
  sku            String           @unique @db.VarChar(100)
  category       String           @db.VarChar(255)
  price          Decimal          @db.Decimal(10, 2)
  stock          Int              @default(0)
  description    String
  active         Boolean          @default(true)
  created_at     DateTime         @default(now())
  updated_at     DateTime         @updatedAt @default(now())
  is_deleted     Boolean?         @default(false)
  deleted_at     DateTime?
  id_user        String?          @db.VarChar(40)
  User           User?            @relation(fields: [id_user], references: [id])

  @@index([id_user, created_at])
}
