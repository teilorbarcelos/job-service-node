import { describe, it, expect, vi, beforeEach } from 'vitest';
import { {{driverName}}Driver } from '@/infra/storage/drivers/{{driverName}}Driver.js';
{{{testImports}}}

{{{testMocks}}}

describe('{{driverName}}Driver', () => {
  let driver: {{driverName}}Driver;
  let mockClient: any;

  beforeEach(() => {
    vi.clearAllMocks();
    {{{testEnvSetup}}}
    mockClient = {{{mockClientSetup}}};
    driver = new {{driverName}}Driver(mockClient, 'test-bucket');
  });

  it('should save a file correctly', async () => {
    {{{testSaveFileLogic}}}
    const result = await driver.saveFile('test.txt', 'data');
    expect(result).toContain('test.txt');
  });

  it('should get a file correctly', async () => {
    {{{testGetFileLogic}}}
    const result = await driver.getFile('test.txt');
    expect(result.toString()).toBe('data');
  });

  it('should delete a file correctly', async () => {
    {{{testDeleteFileLogic}}}
    await driver.deleteFile('http://localhost/test.txt');
  });

  it('should check if a file exists', async () => {
    {{{testExistsLogic}}}
    const result = await driver.exists('test.txt');
    expect(result).toBe(true);
  });

  it('should return a URL', () => {
    const result = driver.getUrl('test.txt');
    expect(result).toContain('test.txt');
  });

  it('should return false if file does not exist', async () => {
    {{{testExistsLogicError}}}
    const result = await driver.exists('test.txt');
    expect(result).toBe(false);
  });

  it('should throw error if getFile returns empty body', async () => {
    {{{testGetFileEmptyLogic}}}
    await expect(driver.getFile('test.txt')).rejects.toThrow();
  });

  it('should return early if deleteFile receives invalid URL', async () => {
    await driver.deleteFile('');
    // No error should be thrown and mock client should not be called
  });

  {{{extraTests}}}

  it('should handle errors gracefully', async () => {
    {{{testErrorLogic}}}
    
    await expect(driver.saveFile('error.txt', 'data')).rejects.toThrow();
    await expect(driver.getFile('error.txt')).rejects.toThrow();
    await expect(driver.deleteFile('error.txt')).rejects.toThrow();
  });
  
  {{{constructorTests}}}
});
