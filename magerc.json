{
  "scripts": [
    { "name": "🛠️ Install Dependencies", "command": "npm install" },
    { "name": "🧹 Lint & Fix Code", "command": "bun run lint" },
    { "name": "🚀 Start Job Runner (dev)", "command": "make dev" },
    { "name": "🐳 Infrastructure: Start All (Postgres, Redis, RabbitMQ)", "command": "make infra-up" },
    { "name": "🐳 Infrastructure: Stop Services", "command": "make infra-stop" },
    { "name": "🐳 Infrastructure: Remove Containers", "command": "make infra-down" },
    { "name": "🧹 Infrastructure: Full Clean (Prune)", "command": "make infra-clean" },
    { "name": "🧪 Run Unit Tests", "command": "make test" },
    { "name": "📊 Code Coverage Report", "command": "make coverage" },
    { "name": "🏗️ Generate New Job (make generate-job name=Cleanup)", "command": "make generate-job" },
    { "name": "🗄️ Generate Prisma Client", "command": "bun run prisma:gen" }
  ],
  "replacements": [
    { "path": "package.json", "pattern": "job-service-node" }
  ]
}
